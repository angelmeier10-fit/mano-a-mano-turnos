rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Solo el dueño autenticado puede leer/escribir servicios, disponibilidad y notas de clientes.
    // Cualquiera (incluso sin login) puede LEER disponibilidad y servicios, para poder reservar.
    // Cualquiera puede CREAR un turno (reservar), pero no editar ni borrar turnos existentes,
    // ni leer la lista completa de turnos/clientes (eso es privado, solo para vos).

    function isOwner() {
      return request.auth != null && request.auth.uid == resource.data.ownerId;
    }
    function isSignedIn() {
      return request.auth != null;
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /availability/{slotId} {
      allow read: if true;
      allow write: if isSignedIn();
      // App pública: marcar un cupo como reservado al confirmar turno.
      allow update: if !resource.data.get('booked', false)
                    && request.resource.data.booked == true
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['booked']);
      // App pública: liberar un cupo al cancelar o reprogramar un turno.
      allow update: if resource.data.get('booked', false)
                    && request.resource.data.booked == false
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['booked']);
    }

    match /appointments/{apptId} {
      // cualquiera puede crear una reserva (vía la app pública)
      allow create: if (request.resource.data.status == "confirmado"
                        || request.resource.data.status == "pendiente")
                    && request.resource.data.clientName is string
                    && request.resource.data.clientName.size() > 0;
      // solo vos (logueado) podés leer la lista completa, editar o borrar
      allow read, update, delete: if isSignedIn();
      // Cliente sin login puede cancelar/reprogramar su propio turno.
      // Solo se permite cambiar status y cancelProof, y únicamente si el turno está activo.
      // - Reserva pública (tiene cancelToken): exige cancelProof correcto como prueba de identidad.
      // - Turno manual sin cancelToken (cargado por el profesional): se permite sin prueba adicional.
      allow update: if !isSignedIn()
                    && (resource.data.status == "confirmado" || resource.data.status == "pendiente")
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelProof'])
                    && (
                         (resource.data.get('cancelToken', null) != null
                          && request.resource.data.cancelProof == resource.data.cancelToken)
                         || resource.data.get('cancelToken', null) == null
                       );
    }

    match /clients/{clientId} {
      // cualquiera puede crear su propia ficha al reservar (vía la app pública)
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() > 0;
      // los datos de clientes son privados: solo vos los leés, editás o borrás
      allow read, update, delete: if isSignedIn();
    }

    match /businessInfo/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Gift Cards: cualquiera puede crear y leer por código. Solo autenticado puede actualizar (activar/canjear).
    match /giftCards/{code} {
      allow create: if request.resource.data.status == "pending"
                    && request.resource.data.fromName is string
                    && request.resource.data.fromName.size() > 0
                    && request.resource.data.buyerPhone is string
                    && request.resource.data.buyerPhone.size() > 0;
      allow read: if true;
      allow update: if isSignedIn()
                    || (
                      // Cliente puede canjear: cambiar status a "used" y agregar apptId
                      resource.data.status == "active"
                      && request.resource.data.status == "used"
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'apptId', 'usedAt'])
                    )
                    || (
                      // Cliente puede restaurar al cancelar: volver a "active" y limpiar apptId/usedAt
                      resource.data.status == "used"
                      && request.resource.data.status == "active"
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'apptId', 'usedAt'])
                    )
                    || (
                      // Cliente puede actualizar apptId al reprogramar (gift card sigue "used")
                      resource.data.status == "used"
                      && request.resource.data.status == "used"
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['apptId'])
                    );
      allow delete: if isSignedIn();
    }

    // Combos de sesiones prepagas: cualquiera puede pedir uno (queda "pending" hasta que
    // el profesional confirma el pago). Solo autenticado puede activar/canjear/borrar.
    match /combos/{comboId} {
      allow create: if request.resource.data.status == "pending"
                    && request.resource.data.clientName is string
                    && request.resource.data.clientName.size() > 0
                    && request.resource.data.clientPhone is string
                    && request.resource.data.clientPhone.size() > 0
                    && (request.resource.data.totalSessions == 2 || request.resource.data.totalSessions == 3);
      allow read: if true;
      allow update: if isSignedIn()
                    || (
                      // Cliente puede canjear una sesión al reservar: baja sessionsRemaining en 1
                      // y actualiza status/usedApptIds.
                      resource.data.status == "active"
                      && request.resource.data.sessionsRemaining == resource.data.sessionsRemaining - 1
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'sessionsRemaining', 'usedApptIds'])
                    )
                    || (
                      // Cliente puede restaurar una sesión al cancelar: sube sessionsRemaining en 1
                      // y vuelve a "active".
                      request.resource.data.status == "active"
                      && request.resource.data.sessionsRemaining == resource.data.sessionsRemaining + 1
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'sessionsRemaining', 'usedApptIds'])
                    )
                    || (
                      // Cliente puede actualizar el apptId dentro de usedApptIds al reprogramar.
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedApptIds'])
                    );
      allow delete: if isSignedIn();
    }

    // Índice liviano para deduplicar clientes desde la app pública sin exponer datos sensibles.
    // ID del documento = dígitos del teléfono. Solo contiene { clientId }.
    match /phoneIndex/{phoneDigitsId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isSignedIn();
    }

    // Índice de reservas por teléfono: permite al cliente ver y gestionar sus turnos sin login.
    // No almacena cancelToken (ese solo vive en localStorage del cliente).
    match /phoneIndex/{phoneDigitsId}/bookings/{apptId} {
      allow read, write: if true;
    }

    // Índice liviano público con el descuento VIP del cliente, sin datos sensibles.
    // ID del documento = dígitos del teléfono.
    match /clientDiscounts/{phoneDigitsId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
